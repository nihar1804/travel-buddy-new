# GOOGLE_MAPS_PLATFORM_KEY: Required for Google Maps integration.
GOOGLE_MAPS_PLATFORM_KEY="YOUR_GOOGLE_MAPS_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# EMAIL_USER: SMTP email user for booking requests.
